# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# OpenAI — análisis de imágenes (visión) y transcripción de audio
OPENAI_API_KEY=sk-...
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Pipeline config
BATCH_SIZE=10

# Precio de referencia de supermercado (extractor Node)
PRECIO_REFERENCIA_ENABLED=1
# Carpeta del proyecto Node con el extractor (default: hermano del repo)
# PRECIO_REFERENCIA_DIR=../scrapening-ofertas
# Supermercados a consultar (orden = preferencia)
PRECIO_MERCADOS=jumbo,santaisabel
# Caché: segundos de validez de un precio (12h) y timeout por consulta
PRECIO_CACHE_TTL=43200
PRECIO_TIMEOUT=90

# Enriquecimiento del local.
# SIN key → usa OpenStreetMap/Nominatim GRATIS (dirección + Maps; sin teléfono/horario).
# CON key de Google Places → datos ricos (teléfono, horario, foto):
# GOOGLE_MAPS_API_KEY=AIza...
ENRIQUECIMIENTO_ENABLED=1
# User-Agent requerido por Nominatim (política de uso de OSM)
NOMINATIM_UA=datazos-rm/1.0 (contacto@tudominio.cl)

# Publicación multicanal (cada canal es opcional; sin credenciales se omite)
# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# WhatsApp Cloud API (Meta)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_TO=
# Meta Graph (Instagram + Facebook)
META_TOKEN=
IG_USER_ID=
FB_PAGE_ID=
# TikTok (requiere aprobación de la Content Posting API)
TIKTOK_TOKEN=
# Cuántos datazos publica cada corrida del publicador espaciado
PUBLICAR_BATCH=1
